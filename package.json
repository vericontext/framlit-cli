{
  "name": "framlit",
  "version": "0.9.0",
  "description": "Framlit CLI — generate Remotion videos from your terminal. Ships an MCP server for Claude/Cursor/VS Code on the side.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "framlit": "dist/cli/index.js",
    "framlit-mcp": "dist/mcp/server.js"
  },
  "scripts": {
    "dev": "tsx watch src/mcp/server.ts",
    "dev:cli": "tsx src/cli/index.ts",
    "build": "tsc",
    "start": "node dist/mcp/server.js",
    "start:cli": "node dist/cli/index.js",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm run test"
  },
  "keywords": [
    "framlit",
    "cli",
    "remotion",
    "video",
    "ai",
    "mcp",
    "cursor",
    "claude"
  ],
  "author": "Framlit",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "eslint": "^8.57.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "AGENTS.md",
    "SKILL.md",
    "CONTEXT.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vericontext/framlit-cli.git"
  },
  "bugs": {
    "url": "https://github.com/vericontext/framlit-cli/issues"
  },
  "homepage": "https://framlit.app/developers"
}
