{
  "name": "framlit-mcp",
  "version": "0.2.0",
  "description": "MCP server and CLI for Framlit - AI-powered video generation",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "framlit-mcp": "./dist/mcp/server.js",
    "framlit": "./dist/cli/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/mcp/server.ts",
    "dev:cli": "tsx src/cli/index.ts",
    "build": "tsc",
    "start": "node dist/mcp/server.js",
    "start:cli": "node dist/cli/index.js",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "framlit",
    "remotion",
    "video",
    "ai",
    "cursor",
    "cli"
  ],
  "author": "Framlit",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "eslint": "^8.57.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/framlit/framlit-mcp.git"
  }
}
